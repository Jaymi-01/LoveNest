rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isPartner(nestId) {
      return request.auth != null &&
        (request.auth.uid in get(/databases/$(database)/documents/nests/$(nestId)).data.users);
    }

    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
      
      allow update: if request.auth != null && (
        // 1. Own profile
        request.auth.uid == userId || 
        // 2. Someone sending a request to this user
        (request.resource.data.pairingRequestFrom == request.auth.uid) ||
        // 3. Someone accepting/declining a request from this user
        (resource.data.pendingPairingWith == request.auth.uid)
      );
      
      allow list: if request.auth != null;
    }

    match /nests/{nestId} {
      allow read: if isPartner(nestId);
      allow create: if request.auth != null;
      allow update: if isPartner(nestId);

      match /messages/{messageId} { allow read, write: if isPartner(nestId); }
      match /events/{eventId} { allow read, write: if isPartner(nestId); }
      match /scrapbook/{photoId} { allow read, write: if isPartner(nestId); }
      match /journals/{journalId} { allow read, write: if isPartner(nestId); }
      match /love_letters/{letterId} {
        allow read, create: if isPartner(nestId);
        allow update, delete: if isPartner(nestId) && resource.data.senderId == request.auth.uid;
      }
    }
  }
}
